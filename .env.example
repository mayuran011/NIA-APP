# Copy to .env and set values. Never commit .env to git.
# For Hostinger Node.js: set these in hPanel → Node.js app → Environment variables.

NODE_ENV=production
PORT=3000
# Use your actual domain (e.g. https://mediumslateblue-hawk-820028.hostingersite.com/)
SITE_URL=https://mediumslateblue-hawk-820028.hostingersite.com

# Remote MySQL (Hostinger)
DB_HOST=srv2061.hstgr.io
DB_NAME=u454323635_niaapp_php
DB_USER=u454323635_niaapp_php
DB_PASSWORD=your_mysql_password_here
DB_CHARSET=utf8mb4
DB_PREFIX=nia_

# JWT for login sessions (generate a long random string)
JWT_SECRET=your_long_random_secret_here

# Optional: media files path (default: ./media in project root)
# MEDIA_FOLDER=/path/to/media
